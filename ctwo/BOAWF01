$any = "${Env:ProgramFiles(x86)}\AnyDesk\AnyDesk.exe"
if (-not (Test-Path -Path $any -ErrorAction SilentlyContinue)){
    if (Get-Command winget -ErrorAction SilentlyContinue) {
        Write-Host "[I]Installing via winget"
        winget install -e --id AnyDesk.AnyDesk --accept-source-agreements --accept-package-agreements --silent    
    } else {
        $wc = New-Object System.Net.WebClient
        $wc.DownloadFile("https://download.anydesk.com/AnyDesk.exe", "$env:tmp\any.exe")
        Start-Process -FilePath "$env:tmp\any.exe" -ArgumentList "--install `"${Env:ProgramFiles(x86)}\AnyDesk`" --silent" -Verb RunAs -Wait -ErrorAction SilentlyContinue
    }
}
Write-Host "[I]Setting password and get id"
Start-Process -FilePath $any -ArgumentList "--start"
Start-Sleep -Seconds 7
echo "XbeaqrxM4!" | & $any --set-password
$output = ""
$pr = New-Object System.Diagnostics.ProcessStartInfo
$pr.FileName = $any
$pr.Arguments = "--get-status"
$pr.UseShellExecute = $false
$pr.RedirectStandardOutput = $true
$pr.RedirectStandardError = $true
do {
    $process = [System.Diagnostics.Process]::Start($pr)
    $process.WaitForExit()
    $output = $process.StandardOutput.ReadToEnd()
    $errors = $process.StandardError.ReadToEnd()
    Write-Host "Output : $output"
    Start-Sleep -Seconds 1
} until ($output -eq "online")
$pr.Arguments = "--get-id"
$process = [System.Diagnostics.Process]::Start($pr)
$process.WaitForExit()
$id = $process.StandardOutput.ReadToEnd()
Write-Host "ID : $id"
