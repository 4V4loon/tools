$any = "${Env:ProgramFiles}\RustDesk\rustdesk.exe"
if (-not (Test-Path -Path $any -ErrorAction SilentlyContinue)){
    if (Get-Command winget -ErrorAction SilentlyContinue) {
        Write-Host "[I]Installing via winget"
        winget install -e --id RustDesk.RustDesk --accept-source-agreements --accept-package-agreements --silent    
    } else {
        $wc = New-Object System.Net.WebClient
        $wc.DownloadFile("https://github.com/rustdesk/rustdesk/releases/download/1.4.5/rustdesk-1.4.5-x86_64.exe", "$env:tmp\any.exe")
        Start-Process -FilePath "$env:tmp\any.exe" -ArgumentList "--silent-install" -Verb RunAs -Wait -ErrorAction SilentlyContinue
        Start-Process -FilePath $any -ArgumentList "--install-service" -Verb RunAs -ErrorAction SilentlyContinue
    }
}
Write-Host "[I]Setting password and get id"
Start-Sleep -Seconds 7
Start-Process -FilePath $any -ArgumentList "--password XbeaqrxM4!" -Wait
$pr = New-Object System.Diagnostics.ProcessStartInfo
$pr.FileName = $any
$pr.UseShellExecute = $false
$pr.RedirectStandardOutput = $true
$pr.RedirectStandardError = $true
$pr.Arguments = "--get-id"
$process = [System.Diagnostics.Process]::Start($pr)
$process.WaitForExit()
$id = $process.StandardOutput.ReadToEnd()
Write-Host "ID : $id"
